{
  "name": "pi-pr-companion",
  "version": "0.1.0",
  "description": "Pi package for PR status, review sessions, and branch switching",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pr",
    "review"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayagmar/pi-pr-companion.git"
  },
  "homepage": "https://github.com/ayagmar/pi-pr-companion",
  "bugs": {
    "url": "https://github.com/ayagmar/pi-pr-companion/issues"
  },
  "files": [
    "src/",
    "prompts/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke-test": "node --import=tsx ./scripts/smoke-test.mjs",
    "test": "node --import=tsx --test ./test/*.test.ts",
    "check": "tsc --noEmit -p tsconfig.json && node --import=tsx ./scripts/smoke-test.mjs && node --import=tsx --test ./test/*.test.ts && eslint . --max-warnings=0 && prettier --check .",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:first": "release-it --first-release"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@mariozechner/pi-tui": "^0.62.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^22.19.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  }
}
